  },
  "devDependencies": {
    "@antdv-next/auto-import-resolver": "^1.1.0",
    "@antdv-next/tailwind": "^1.1.1",
    "@tailwindcss/vite": "^4.3.3",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
